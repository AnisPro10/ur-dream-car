# Configuration Supabase (Lovable Cloud) — copier en .env et renseigner les valeurs.
# La clé publishable/anon est publique par conception (exposée côté client via VITE_).
# NE JAMAIS mettre ici une clé secrète (SUPABASE_SERVICE_ROLE_KEY, Stripe, etc.) :
# les secrets vont uniquement dans les variables d'environnement de l'hébergeur.
SUPABASE_PROJECT_ID=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
